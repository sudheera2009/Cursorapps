# Release signing configuration template.
# 1. Generate an upload keystore:
#    keytool -genkey -v -keystore ~/aura-meter-upload.jks \
#      -keyalg RSA -keysize 2048 -validity 10000 -alias upload
# 2. Copy this file to `key.properties` (same directory) and fill in the values.
# 3. NEVER commit the real key.properties or the .jks file.

storePassword=your-keystore-password
keyPassword=your-key-password
keyAlias=upload
storeFile=/absolute/path/to/aura-meter-upload.jks
